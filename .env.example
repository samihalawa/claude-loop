# Claude Loop Environment Configuration
# Copy this file to .env and customize the values for your environment

# WebUI Configuration
WEBUI_PORT=3333
WEBUI_MAX_CONNECTIONS=5
WEBUI_TOKEN_EXPIRY_HOURS=24
WEBUI_MAX_OUTPUT_ENTRIES=50

# Claude Loop Configuration
CLAUDE_LOOP_MAX_ITERATIONS=10
CLAUDE_LOOP_MAX_TURNS=30
CLAUDE_COMMAND=claude

# Timeout Configuration (in milliseconds)
CONNECTION_TIMEOUT=300000
HANDSHAKE_TIMEOUT=10000
REQUEST_TIMEOUT=5000
PING_INTERVAL=30000
CLEANUP_INTERVAL=60000
RECONNECT_BASE_DELAY=2000
RECONNECT_MAX_DELAY=30000
SESSION_SETTLE_TIME=2000
WEBUI_STOP_DELAY=10000

# Rate Limiting
REQUESTS_PER_MINUTE=60
CONNECTION_ATTEMPTS_PER_IP=10
RATE_LIMIT_WINDOW=60000

# Connection Limits
MAX_PAYLOAD_SIZE=16777216
MAX_MESSAGE_LENGTH=10000

# Test Configuration
TEST_APP_PORT=3001
TEST_DATA_PORT=3334
TEST_STRESS_PORT=3335
TEST_DURATION=5000
TEST_TIMEOUT=15000
STRESS_TEST_CYCLES=10
CONCURRENT_CLIENTS=5
MESSAGE_VOLUME=100
MEMORY_TEST_ITERATIONS=1000

# Retry Configuration
MAX_RETRIES=3
BACKOFF_MULTIPLIER=2.0
JITTER_FACTOR=0.1

# Claude Desktop Configuration Path (macOS)
CLAUDE_CONFIG_PATH="~/Library/Application Support/Claude/claude_desktop_config.json"

# Development/Debug Settings
NODE_ENV=development
DEBUG_MODE=false
VERBOSE_LOGGING=false