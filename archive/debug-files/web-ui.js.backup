const express = require('express');
const http = require('http');
const WebSocket = require('ws');
const path = require('path');
const chalk = require('chalk');
const crypto = require('crypto');
const NetworkHelper = require('./utils/network-helper');
const { performanceOptimizer } = require('./utils/performance-optimizer');
const SecurityHeaders = require('./utils/security-headers');
const TimeBasedFilter = require('./utils/time-based-filter');
const TemplateRenderer = require('./utils/template-renderer');
const logger = require('./utils/unified-logger');
const {
    TIMEOUTS,
    CONNECTION_LIMITS,
    SECURITY,
    PORTS,
    WS_CLOSE_CODES
} = require('./config/constants');

// JSON sanitization to prevent prototype pollution
function sanitizeJSON(obj, maxDepth = 10, currentDepth = 0) {
    if (currentDepth > maxDepth) {
        throw new Error('JSON object too deeply nested');
    }
    
    if (obj === null || typeof obj !== 'object') {
        return obj;
    }
    
    if (Array.isArray(obj)) {
        return obj.map(item => sanitizeJSON(item, maxDepth, currentDepth + 1));
    }
    
    const sanitized = {};
    for (const [key, value] of Object.entries(obj)) {
        // Prevent prototype pollution
        if (key === '__proto__' || key === 'constructor' || key === 'prototype') {
            continue;
        }
        sanitized[key] = sanitizeJSON(value, maxDepth, currentDepth + 1);
    }
    
    return sanitized;
}

class WebUI {
    constructor(port = parseInt(process.env.WEBUI_PORT) || PORTS.WEBUI_DEFAULT) {
        this.port = port;
        this.app = express();
        this.server = http.createServer(this.app);
        
        // Enhanced WebSocket server configuration with security settings and performance optimizations
        this.wss = new WebSocket.Server({ 
            server: this.server,
            maxConnections: parseInt(process.env.WEBUI_MAX_CONNECTIONS) || CONNECTION_LIMITS.MAX_CONNECTIONS,
            perMessageDeflate: {
                // Enable compression with security limits
                threshold: 1024, // Only compress messages larger than 1KB
                concurrencyLimit: 10, // Limit concurrent compression operations
                memLevel: 7, // Balance memory usage vs compression ratio
                chunkSize: 16 * 1024 // 16KB chunks for better memory management
            },
            clientTracking: true, // Enable client tracking for better cleanup
            handshakeTimeout: parseInt(process.env.WEBUI_HANDSHAKE_TIMEOUT) || TIMEOUTS.HANDSHAKE,
            maxPayload: parseInt(process.env.WEBUI_MAX_PAYLOAD) || CONNECTION_LIMITS.MAX_PAYLOAD_SIZE,
            skipUTF8Validation: false, // Enable UTF8 validation for security
            verifyClient: (info) => {
                // Enhanced client verification using TimeBasedFilter
                const ip = NetworkHelper.getClientIP(info.req);
                
                // Check if IP is rate limited using TimeBasedFilter
                const connectionLimit = TimeBasedFilter.isRateLimited(
                    ip, 
                    'connection', 
                    CONNECTION_LIMITS.MAX_CONNECTIONS * 2, 
                    300000 // 5 minutes
                );
                
                if (connectionLimit) {
                    logger.info(chalk.red(`🚫 Connection blocked from ${ip}: too many attempts`));
                    return false;
                }
                
                // Enhanced header validation using NetworkHelper
                const userAgent = info.req.headers['user-agent'];
                if (!NetworkHelper.isValidUserAgent(userAgent)) {
                    logger.info(chalk.yellow(`🚫 Invalid user agent from ${NetworkHelper.sanitizeIPForLogging(ip)}`));
                    return false;
                }
                
                return true;
            }
        });
        
        this.clients = new Set();
        this.connectionCount = 0;
        this.maxConnections = parseInt(process.env.WEBUI_MAX_CONNECTIONS) || 5;
        this.sessionData = {
            iterations: 0,
            currentPhase: 'Starting...',
            output: [],
            startTime: Date.now(),
            isRunning: false
        };
        
        // Generate secure session token with higher entropy and expiration
        // Generate high-entropy session token (512 bits)
        this.sessionToken = crypto.randomBytes(64).toString('hex');
        this.tokenExpiry = Date.now() + (parseInt(process.env.WEBUI_TOKEN_EXPIRY_HOURS) || 24) * 60 * 60 * 1000; // 24 hour default
        // Only show first 8 characters for security
        const maskedToken = this.sessionToken.substring(0, 8) + '...';
        logger.info(chalk.cyan(`🔐 WebUI Access Token: ${maskedToken}`));
        logger.info(chalk.gray('Add this token as ?token=<token> to the URL for access'));
        logger.info(chalk.gray(`Token expires: ${new Date(this.tokenExpiry).toLocaleString()}`));
        logger.info(chalk.yellow('⚠️  For security, full token is not displayed. Check environment or config for full token.'));
        
        // Enhanced rate limiting with memory management using performance optimizer
        this.requestCounts = new Map();
        this.connectionAttempts = new Map(); // Track connection attempts per IP
        
        // Use managed intervals for automatic cleanup
        performanceOptimizer.setManagedInterval(() => {
            this.cleanupRateLimiting();
        }, 60000, 'webui-cleanup'); // Reset counts every minute
        
        // Connection health monitoring with managed timer
        performanceOptimizer.setManagedInterval(() => {
            this.pingClients();
        }, 30000, 'webui-ping'); // Ping clients every 30 seconds
        
        this.setupMiddleware();
        this.setupRoutes();
        this.setupWebSocket();
    }

    // Helper method to get client IP address using centralized NetworkHelper
    getClientIP(req) {
        return NetworkHelper.getClientIP(req);
    }

    // Helper method to track connection attempts using TimeBasedFilter
    trackConnectionAttempt(clientIP) {
        const result = TimeBasedFilter.trackAndCheck(
            clientIP, 
            'connection', 
            CONNECTION_LIMITS.MAX_CONNECTIONS * 2, 
            300000 // 5 minutes
        );
        
        // Log if too many attempts
        if (!result.allowed) {
            logger.info(chalk.yellow(`🚨 Excessive connection attempts from ${clientIP}: ${result.currentCount} in 5 minutes`));
        }
        
        return result;
    }

    // Helper method to clean up rate limiting data (now delegated to TimeBasedFilter)
    cleanupRateLimiting() {
        const stats = TimeBasedFilter.cleanupAll();
        if (stats.cleanedKeys > 0) {
            logger.info(chalk.gray(`🧹 Cleaned up ${stats.cleanedKeys} expired tracking entries, ${stats.remainingKeys} remaining`));
        }
        
        // Clean up legacy request counts if still present
        if (this.requestCounts && this.requestCounts.size > 0) {
            const now = Date.now();
            const windowStart = now - 60000; // 1 minute window
            
            for (const [ip, requests] of this.requestCounts.entries()) {
                const recentRequests = requests.filter(time => time > windowStart);
                if (recentRequests.length === 0) {
                    this.requestCounts.delete(ip);
                } else {
                    this.requestCounts.set(ip, recentRequests);
                }
            }
        }
    }

    // Helper method to ping clients for connection health
    pingClients() {
        if (this.clients.size === 0) return;
        
        const deadClients = [];
        this.clients.forEach(client => {
            if (client.readyState === WebSocket.OPEN) {
                try {
                    client.ping();
                    // Check if client responded to last ping
                    if (Date.now() - client.lastPong > 60000) { // 1 minute timeout
                        logger.info(chalk.yellow(`🔌 Client ${client.clientIP} appears unresponsive, closing connection`));
                        client.close(1000, 'Ping timeout');
                        deadClients.push(client);
                    }
                } catch (error) {
                    logger.error(`Error pinging client ${client.clientIP}:`, error.message);
                    deadClients.push(client);
                }
            } else {
                deadClients.push(client);
            }
        });
        
        // Clean up dead connections
        deadClients.forEach(client => {
            this.clients.delete(client);
        });
        this.connectionCount = this.clients.size;
    }

    // Helper method to regenerate token
    regenerateToken() {
        this.sessionToken = crypto.randomBytes(32).toString('hex');
        this.tokenExpiry = Date.now() + (24 * 60 * 60 * 1000); // 24 hours from now
        logger.info(chalk.cyan(`🔐 New WebUI Access Token: ${this.sessionToken}`));
        logger.info(chalk.gray(`Token expires: ${new Date(this.tokenExpiry).toLocaleString()}`));
    }

    // Helper method to safely send data to a client
    sendToClient(ws, data) {
        if (ws.readyState === WebSocket.OPEN) {
            try {
                const message = JSON.stringify(data);
                ws.send(message);
            } catch (error) {
                logger.error(`Error sending data to client ${ws.clientIP}:`, error.message);
                this.clients.delete(ws);
                this.connectionCount = this.clients.size;
            }
        }
    }

    // Helper method to handle WebSocket messages with rate limiting using TimeBasedFilter
    handleWebSocketMessage(ws, message) {
        const maxMessages = parseInt(process.env.WEBUI_MAX_WS_MESSAGES_PER_MINUTE) || 30;
        const rateLimitResult = TimeBasedFilter.trackAndCheck(
            ws.clientIP, 
            'websocket_message', 
            maxMessages, 
            60000 // 1 minute
        );
        
        if (!rateLimitResult.allowed) {
            logger.info(chalk.yellow(`🚫 WebSocket message rate limit exceeded for ${ws.clientIP}: ${rateLimitResult.currentCount}/${maxMessages}`));
            ws.close(1008, 'Message rate limit exceeded');
            return;
        }
        
        try {
            const rawData = JSON.parse(message);
            const data = sanitizeJSON(rawData); // Sanitize to prevent prototype pollution
            // Handle specific message types here if needed
            logger.info(chalk.gray(`📨 WebSocket message from ${ws.clientIP}:`, data.type || 'unknown'));
        } catch (error) {
            logger.error(`Invalid WebSocket message from ${ws.clientIP}:`, error.message);
        }
    }

    
    // Standardized error response method
    sendErrorResponse(res, statusCode, errorMessage, errorCode = null) {
        const errorResponse = {
            error: true,
            message: errorMessage,
            statusCode: statusCode,
            timestamp: new Date().toISOString()
        };
        
        if (errorCode) {
            errorResponse.code = errorCode;
        }
        
        // Add retry information for rate limiting
        if (statusCode === 429) {
            errorResponse.retryAfter = 60; // seconds
        }
        
        res.status(statusCode).json(errorResponse);
    }

    setupMiddleware() {
        // Enhanced CORS middleware with security considerations
        this.app.use((req, res, next) => {
            const origin = req.headers.origin;
            const allowedOrigins = [
                'http://localhost:3000',
                'http://localhost:3001',
                'http://127.0.0.1:3000',
                'http://127.0.0.1:3001'
            ];
            
            // Allow localhost origins for development
            if (origin && (allowedOrigins.includes(origin) || /^http:\/\/localhost:\d+$/.test(origin))) {
                res.setHeader('Access-Control-Allow-Origin', origin);
            }
            
            res.setHeader('Access-Control-Allow-Methods', 'GET, POST, OPTIONS');
            res.setHeader('Access-Control-Allow-Headers', 'Content-Type, Authorization');
            res.setHeader('Access-Control-Max-Age', '86400'); // 24 hours
            res.setHeader('Access-Control-Allow-Credentials', 'false'); // Security: don't allow credentials
            
            // Handle preflight requests
            if (req.method === 'OPTIONS') {
                res.status(204).send();
                return;
            }
            
            next();
        });
        // Use centralized security headers middleware
        this.app.use(SecurityHeaders.middleware());

        // Enhanced rate limiting middleware using TimeBasedFilter
        this.app.use((req, res, next) => {
            // Skip rate limiting for WebSocket upgrade requests
            if (req.headers.upgrade === 'websocket') {
                return next();
            }
            
            const clientIP = this.getClientIP(req);
            const maxRequests = parseInt(process.env.WEBUI_MAX_REQUESTS_PER_MINUTE) || 30;
            
            const rateLimitResult = TimeBasedFilter.trackAndCheck(
                clientIP, 
                'http_request', 
                maxRequests, 
                60000 // 1 minute
            );
            
            if (!rateLimitResult.allowed) {
                logger.info(chalk.yellow(`🚫 Rate limit exceeded for IP: ${clientIP} (${rateLimitResult.currentCount}/${maxRequests})`));
                this.sendErrorResponse(res, 429, 'Rate limit exceeded', 'RATE_LIMIT_EXCEEDED');
                return;
            }
            
            next();
        });

        // Enhanced token authentication with expiration check
        this.app.use((req, res, next) => {
            // Skip token validation for WebSocket upgrade requests
            if (req.headers.upgrade === 'websocket') {
                return next();
            }
            
            const token = req.query.token;
            
            // Check token expiration
            if (Date.now() > this.tokenExpiry) {
                logger.info(chalk.red('🔒 Token has expired, generating new token'));
                this.regenerateToken();
                res.status(401).json({ 
                    error: 'Token expired', 
                    message: 'Check console for new token'
                });
                return;
            }
            
            // Validate token using timing-safe comparison
            if (!token || !this.timingSafeTokenCompare(token, this.sessionToken)) {
                const clientIP = this.getClientIP(req);
                logger.info(chalk.yellow(`🚫 Invalid token attempt from IP: ${clientIP}`));
                res.status(401).json({ 
                    error: 'Invalid or missing token',
                    message: 'Add ?token=<your_token> to the URL'
                });
                return;
            }
            
            next();
        });
    }

    setupRoutes() {
        // Add security headers to all responses
        this.app.use((req, res, next) => {
            res.setHeader('X-Content-Type-Options', 'nosniff');
            res.setHeader('X-Frame-Options', 'DENY');
            res.setHeader('X-XSS-Protection', '1; mode=block');
            res.setHeader('Referrer-Policy', 'strict-origin-when-cross-origin');
            res.setHeader('Content-Security-Policy', 
                "default-src 'self'; " +
                "script-src 'self' 'unsafe-inline' cdn.jsdelivr.net cdnjs.cloudflare.com; " +
                "style-src 'self' 'unsafe-inline' cdn.jsdelivr.net cdnjs.cloudflare.com fonts.googleapis.com; " +
                "font-src 'self' fonts.googleapis.com fonts.gstatic.com; " +
                "connect-src 'self' ws: wss:; " +
                "img-src 'self' data: https:; " +
                "object-src 'none'; " +
                "base-uri 'self'"
            );
            next();
        });

        // Serve the dashboard
        this.app.get('/', async (req, res) => {
            try {
                res.setHeader('Content-Type', 'text/html; charset=utf-8');
                const html = await this.getDashboardHTML();
                res.send(html);
            } catch (error) {
                logger.error('Error serving dashboard:', error.message);
                res.status(500).send('Internal Server Error');
            }
        });

        // API endpoint for session data
        this.app.get('/api/session', (req, res) => {
            res.json(this.sessionData);
        });

        // Health check
        this.app.get('/health', (req, res) => {
            res.json({ status: 'ok', timestamp: new Date().toISOString() });
        });
    }

    setupWebSocket() {
        this.wss.on('connection', (ws, req) => {
            const clientIP = this.getClientIP(req);
            
            // Enhanced connection attempt tracking
            this.trackConnectionAttempt(clientIP);
            
            // Check connection limit BEFORE processing connection
            if (this.clients.size >= this.maxConnections) {
                ws.close(1013, 'Server overloaded');
                logger.info(chalk.yellow(`🚫 Connection rejected: limit reached (${this.clients.size}/${this.maxConnections}) from ${clientIP}`));
                return;
            }
            
            // Enhanced token validation for WebSocket with expiration check
            const url = new URL(req.url, `http://${req.headers.host}`);
            const token = url.searchParams.get('token');
            
            // Check token expiration
            if (Date.now() > this.tokenExpiry) {
                ws.close(1008, 'Token expired');
                logger.info(chalk.red(`🔒 WebSocket connection rejected: token expired for ${clientIP}`));
                return;
            }
            
            if (!token || !this.timingSafeTokenCompare(token, this.sessionToken)) {
                ws.close(1008, 'Invalid token');
                logger.info(chalk.yellow(`🚫 WebSocket connection rejected: invalid token from ${clientIP}`));
                return;
            }
            
            // Add connection metadata
            ws.clientIP = clientIP;
            ws.connectedAt = Date.now();
            ws.lastPong = Date.now();
            ws.isAlive = true;
            
            // Add to clients set and update connection count atomically
            this.clients.add(ws);
            this.connectionCount = this.clients.size; // Keep in sync
            logger.info(chalk.gray(`📱 Web UI client connected from ${clientIP} (${this.connectionCount}/${this.maxConnections})`));
            
            // Set up connection timeout (reduced for security)
            const timeout = setTimeout(() => {
                if (ws.readyState === WebSocket.OPEN) {
                    ws.close(1000, 'Connection timeout');
                }
            }, 180000); // 3 minute timeout (reduced from 5)
            
            // Send current session data safely after a small delay to ensure client is ready
            setTimeout(() => {
                this.sendToClient(ws, {
                    type: 'session_data',
                    data: this.sessionData
                });
            }, 100); // 100ms delay to ensure client readiness

            // Enhanced event handlers
            ws.on('close', (code, reason) => {
                clearTimeout(timeout);
                this.clients.delete(ws);
                this.connectionCount = this.clients.size; // Keep in sync
                logger.info(chalk.gray(`📱 Web UI client disconnected from ${clientIP} (${this.connectionCount}/${this.maxConnections}) - Code: ${code}, Reason: ${reason}`));
            });
            
            ws.on('error', (error) => {
                clearTimeout(timeout);
                logger.error(`WebSocket error from ${clientIP}:`, error.message);
                this.clients.delete(ws);
                this.connectionCount = this.clients.size; // Keep in sync
            });
            
            // Handle pong responses for connection health
            ws.on('pong', () => {
                ws.lastPong = Date.now();
                ws.isAlive = true;
            });
            
            // Rate limiting for WebSocket messages
            ws.messageCount = 0;
            ws.messageWindow = Date.now();
            
            ws.on('message', (data) => {
                try {
                    // Check message size before processing
                    if (data.length > 1000000) { // 1MB limit
                        logger.info(chalk.red(`🚫 Message too large from ${clientIP}: ${data.length} bytes`));
                        ws.close(1009, 'Message too large');
                        return;
                    }
                    
                    // Parse and validate JSON with size limits
                    let message;
                    try {
                        const messageStr = data.toString();
                        message = JSON.parse(messageStr);
                        
                        // Validate message structure
                        if (typeof message !== 'object' || message === null) {
                            throw new Error('Invalid message format');
                        }
                        
                        // Sanitize message content
                        message = sanitizeJSON(message, 5); // Limit nesting depth
                        
                    } catch (parseError) {
                        logger.info(chalk.yellow(`Invalid JSON message from ${clientIP}: ${parseError.message}`));
                        // Send error response but don't close connection
                        this.sendToClient(ws, {
                            type: 'error',
                            message: 'Invalid message format'
                        });
                        return;
                    }
                    
                    // Handle different message types
                    switch (message.type) {
                        case 'ping':
                            this.sendToClient(ws, { type: 'pong', timestamp: Date.now() });
                            break;
                            
                        case 'request_session':
                            this.sendToClient(ws, {
                                type: 'session_data',
                                data: this.sessionData
                            });
                            break;
                            
                        default:
                            // Unknown message type - log but don't error
                            logger.info(chalk.gray(`Unknown message type from ${clientIP}: ${message.type}`));
                            break;
                    }
                    
                } catch (error) {
                    logger.error(chalk.red(`WebSocket message error from ${clientIP}:`), error.message);
                    // Don't close connection for recoverable errors
                    this.sendToClient(ws, {
                        type: 'error',
                        message: 'Message processing error'
                    });
                }
            });
        });
    }

    broadcast(data) {
        if (this.clients.size === 0) return;
        
        // Use try-catch for JSON stringify to prevent crashes
        let message;
        try {
            message = JSON.stringify(data);
        } catch (error) {
            logger.error('Error serializing broadcast data:', error.message);
            return;
        }
        
        const deadClients = [];
        const clientsArray = Array.from(this.clients); // Create snapshot to avoid concurrent modification
        
        clientsArray.forEach(client => {
            if (client.readyState === WebSocket.OPEN) {
                try {
                    client.send(message);
                } catch (error) {
                    logger.error('Error broadcasting to client:', error.message);
                    deadClients.push(client);
                }
            } else {
                deadClients.push(client);
            }
        });
        
        // Clean up dead connections atomically
        if (deadClients.length > 0) {
            deadClients.forEach(client => {
                this.clients.delete(client);
            });
            this.connectionCount = this.clients.size; // Keep in sync
            logger.info(chalk.gray(`🧹 Cleaned up ${deadClients.length} dead connections`));
        }
    }

    // Ping clients to check connection health
    pingClients() {
        if (this.clients.size === 0) return;
        
        const deadClients = [];
        const clientsArray = Array.from(this.clients);
        
        clientsArray.forEach(client => {
            if (client.readyState === WebSocket.OPEN) {
                try {
                    // Send ping and mark as not alive until pong received
                    client.isAlive = false;
                    client.ping();
                    
                    // Set up pong handler
                    client.on('pong', () => {
                        client.isAlive = true;
                        client.lastPong = Date.now();
                    });
                    
                } catch (error) {
                    logger.error('Error pinging client:', error.message);
                    deadClients.push(client);
                }
            } else {
                deadClients.push(client);
            }
        });
        
        // Check for clients that didn't respond to previous ping
        setTimeout(() => {
            const unresponsiveClients = [];
            clientsArray.forEach(client => {
                if (!client.isAlive && client.readyState === WebSocket.OPEN) {
                    unresponsiveClients.push(client);
                    client.terminate();
                }
            });
            
            if (unresponsiveClients.length > 0) {
                logger.info(chalk.gray(`🧹 Terminated ${unresponsiveClients.length} unresponsive connections`));
            }
        }, 5000); // Wait 5 seconds for pong response
        
        // Clean up dead connections
        if (deadClients.length > 0) {
            deadClients.forEach(client => {
                this.clients.delete(client);
            });
            this.connectionCount = this.clients.size;
            logger.info(chalk.gray(`🧹 Cleaned up ${deadClients.length} dead connections during ping`));
        }
    }

    updateSession(updates) {
        // Validate updates to prevent corruption
        if (!updates || typeof updates !== 'object') {
            logger.error('Invalid session update data:', updates);
            return;
        }
        
        // Apply updates atomically
        try {
            Object.assign(this.sessionData, updates);
            
            // Create an efficient deep copy for broadcasting to prevent reference issues
            const sessionCopy = performanceOptimizer.deepClone(this.sessionData);
            
            this.broadcast({
                type: 'session_update',
                data: sessionCopy
            });
        } catch (error) {
            logger.error('Error updating session:', error.message);
        }
    }

    addOutput(output, type = 'info') {
        // Validate input
        if (output === null || output === undefined) {
            logger.warn('Attempting to add null/undefined output, skipping');
            return;
        }
        
        // Sanitize message to prevent XSS and ensure it's a string
        const message = String(output).substring(0, 10000); // Limit message length
        
        // Validate type
        const validTypes = ['info', 'success', 'error', 'warning'];
        const safeType = validTypes.includes(type) ? type : 'info';
        
        const entry = {
            timestamp: new Date().toISOString(),
            type: safeType,
            message: message
        };
        
        // Thread-safe array operations with performance optimization
        try {
            const maxOutputEntries = parseInt(process.env.WEBUI_MAX_OUTPUT_ENTRIES) || 50;
            
            // Use performance-optimized array management
            performanceOptimizer.managedArrayPush(this.sessionData.output, entry, maxOutputEntries);

            this.broadcast({
                type: 'new_output',
                data: entry
            });
        } catch (error) {
            logger.error('Error adding output:', error.message);
        }
    }

    start() {
        return new Promise((resolve, reject) => {
            this.server.listen(this.port, (err) => {
                if (err) {
                    reject(err);
                } else {
                    logger.info(chalk.green(`🌐 Web UI started: http://localhost:${this.port}`));
                    logger.info(chalk.gray('📊 Real-time progress monitoring available'));
                    resolve();
                }
            });
        });
    }

    // Enhanced security and utility methods
    // Note: getClientIP method is defined earlier in the class (line ~121)

    timingSafeTokenCompare(a, b) {
        // Use Node.js built-in crypto.timingSafeEqual when available, fallback to constant-time implementation
        if (!a || !b || typeof a !== 'string' || typeof b !== 'string') {
            return false;
        }
        
        try {
            // Use Node.js crypto.timingSafeEqual for truly secure comparison
            const crypto = require('crypto');
            if (crypto.timingSafeEqual) {
                // Ensure both strings are same length to use timingSafeEqual
                if (a.length !== b.length) {
                    return false;
                }
                const bufferA = Buffer.from(a, 'utf8');
                const bufferB = Buffer.from(b, 'utf8');
                return crypto.timingSafeEqual(bufferA, bufferB);
            }
        } catch (error) {
            // Fallback to manual implementation if crypto not available
        }
        
        // Fallback constant-time comparison
        const maxLength = Math.max(a.length, b.length);
        const paddedA = a.padEnd(maxLength, '\0');
        const paddedB = b.padEnd(maxLength, '\0');
        
        let result = 0;
        for (let i = 0; i < maxLength; i++) {
            result |= paddedA.charCodeAt(i) ^ paddedB.charCodeAt(i);
        }
        
        // Include length comparison in constant time
        result |= a.length ^ b.length;
        return result === 0;
    }

    trackConnectionAttempt(clientIP) {
        const now = Date.now();
        if (!this.connectionAttempts.has(clientIP)) {
            this.connectionAttempts.set(clientIP, []);
        }
        
        const attempts = this.connectionAttempts.get(clientIP);
        // Keep only attempts from the last 5 minutes
        const recentAttempts = attempts.filter(time => now - time < 300000);
        recentAttempts.push(now);
        this.connectionAttempts.set(clientIP, recentAttempts);
        
        // Log suspicious activity (more than 20 attempts in 5 minutes)
        if (recentAttempts.length > 20) {
            logger.info(chalk.red(`🚨 Suspicious connection activity from ${clientIP}: ${recentAttempts.length} attempts in 5 minutes`));
        }
    }

    regenerateToken() {
        this.sessionToken = crypto.randomBytes(48).toString('hex');
        this.tokenExpiry = Date.now() + (parseInt(process.env.WEBUI_TOKEN_EXPIRY_HOURS) || 24) * 60 * 60 * 1000;
        const maskedToken = this.sessionToken.substring(0, 8) + '...';
        logger.info(chalk.cyan(`🔐 New WebUI Access Token: ${maskedToken}`));
        logger.info(chalk.gray(`Token expires: ${new Date(this.tokenExpiry).toLocaleString()}`));
        logger.info(chalk.yellow('⚠️  For security, full token is not displayed. Check environment or config for full token.'));
    }

    cleanupRateLimiting() {
        const now = Date.now();
        const cutoff = now - 60000; // 1 minute ago
        
        // Clean up request counts
        for (const [ip, requests] of this.requestCounts.entries()) {
            const recentRequests = requests.filter(time => time > cutoff);
            if (recentRequests.length === 0) {
                this.requestCounts.delete(ip);
            } else {
                this.requestCounts.set(ip, recentRequests);
            }
        }
        
        // Clean up connection attempts (keep 5 minutes)
        const connectionCutoff = now - 300000;
        for (const [ip, attempts] of this.connectionAttempts.entries()) {
            const recentAttempts = attempts.filter(time => time > connectionCutoff);
            if (recentAttempts.length === 0) {
                this.connectionAttempts.delete(ip);
            } else {
                this.connectionAttempts.set(ip, recentAttempts);
            }
        }
        
        logger.info(chalk.gray(`🧹 Rate limiting cleanup: ${this.requestCounts.size} IPs tracked, ${this.connectionAttempts.size} connection attempts tracked`));
    }

    pingClients() {
        const now = Date.now();
        const deadClients = [];
        
        this.clients.forEach(client => {
            if (client.readyState === WebSocket.OPEN) {
                // Check if client responded to last ping
                if (now - client.lastPong > 60000) { // 1 minute since last pong
                    logger.info(chalk.yellow(`💀 Client ${client.clientIP} appears dead (no pong for ${Math.round((now - client.lastPong) / 1000)}s)`));
                    deadClients.push(client);
                    return;
                }
                
                // Send ping
                try {
                    client.isAlive = false;
                    client.ping();
                } catch (error) {
                    logger.error(`Error pinging client ${client.clientIP}:`, error.message);
                    deadClients.push(client);
                }
            } else {
                deadClients.push(client);
            }
        });
        
        // Clean up dead clients
        deadClients.forEach(client => {
            this.clients.delete(client);
            try {
                client.terminate();
            } catch (error) {
                // Ignore termination errors
            }
        });
        
        if (deadClients.length > 0) {
            this.connectionCount = this.clients.size;
            logger.info(chalk.gray(`🧹 Cleaned up ${deadClients.length} dead WebSocket connections`));
        }
    }

    sendToClient(client, data) {
        if (client.readyState !== WebSocket.OPEN) {
            return false;
        }
        
        try {
            const message = JSON.stringify(data);
            client.send(message);
            return true;
        } catch (error) {
            logger.error(`Error sending to client ${client.clientIP}:`, error.message);
            return false;
        }
    }

    handleWebSocketMessage(ws, message) {
        const now = Date.now();
        
        // Reset message window if needed
        if (now - ws.messageWindow > 60000) { // 1 minute window
            ws.messageCount = 0;
            ws.messageWindow = now;
        }
        
        ws.messageCount++;
        
        // Rate limit messages (max 10 per minute per client)
        const maxMessages = parseInt(process.env.WEBUI_MAX_WS_MESSAGES_PER_MINUTE) || 10;
        if (ws.messageCount > maxMessages) {
            logger.info(chalk.yellow(`🚫 Rate limiting WebSocket messages from ${ws.clientIP}`));
            ws.close(1008, 'Message rate limit exceeded');
            return;
        }
        
        try {
            // Parse and validate message with size limit
            if (message.length > 10000) { // 10KB message limit
                logger.info(chalk.yellow(`🚫 Message too large from ${ws.clientIP}: ${message.length} bytes`));
                ws.close(1009, 'Message too large');
                return;
            }
            
            const rawData = JSON.parse(message);
            const data = sanitizeJSON(rawData); // Sanitize to prevent prototype pollution
            
            // Validate message structure
            if (!data || typeof data !== 'object' || Array.isArray(data)) {
                logger.info(chalk.yellow(`🚫 Invalid message structure from ${ws.clientIP}`));
                return;
            }
            
            // Validate message type
            if (data.type && typeof data.type !== 'string') {
                logger.info(chalk.yellow(`🚫 Invalid message type from ${ws.clientIP}`));
                return;
            }
            
            // Sanitize message type to prevent injection
            const messageType = (data.type || 'unknown').replace(/[^a-zA-Z0-9_-]/g, '').substring(0, 50);
            
            // Handle specific message types with validation
            switch (messageType) {
                case 'ping':
                    this.sendToClient(ws, { type: 'pong', timestamp: now });
                    break;
                case 'subscribe':
                    // Validate subscription requests
                    if (data.channel && typeof data.channel === 'string' && /^[a-zA-Z0-9_-]{1,50}$/.test(data.channel)) {
                        logger.info(chalk.gray(`📨 Valid subscription request from ${ws.clientIP}: ${data.channel}`));
                    }
                    break;
                default:
                    logger.info(chalk.gray(`📨 Received message from ${ws.clientIP}: ${messageType}`));
            }
        } catch (error) {
            logger.error(`Invalid JSON message from ${ws.clientIP}:`, error.message);
            // Count invalid messages for potential abuse detection
            ws.invalidMessageCount = (ws.invalidMessageCount || 0) + 1;
            if (ws.invalidMessageCount > 5) {
                logger.info(chalk.yellow(`🚫 Too many invalid messages from ${ws.clientIP}, closing connection`));
                ws.close(1003, 'Too many invalid messages');
            }
        }
    }

    stop() {
        return new Promise((resolve) => {
            // Clean up managed intervals via performance optimizer
            performanceOptimizer.clearManagedInterval('webui-cleanup');
            performanceOptimizer.clearManagedInterval('webui-ping');
            
            // Close all WebSocket connections gracefully
            this.clients.forEach(client => {
                if (client.readyState === WebSocket.OPEN) {
                    try {
                        client.close(1001, 'Server shutting down');
                    } catch (error) {
                        client.terminate();
                    }
                }
            });
            this.clients.clear();
            
            // Close WebSocket server
            this.wss.close(() => {
                // Close HTTP server
                this.server.close(() => {
                    logger.info(chalk.gray('🌐 Web UI server stopped'));
                    resolve();
                });
            });
        });
    }

    async getDashboardHTML() {
        try {
            // Use TemplateRenderer to render the dashboard template
            return await TemplateRenderer.renderDashboard({
                maxIterations: process.env.CLAUDE_LOOP_MAX_ITERATIONS || '10'
            });
        } catch (error) {
            logger.error('Error rendering dashboard template:', error.message);
            
            // Fallback to simple HTML if template rendering fails
            return `<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Claude Loop - Error</title>
    <style>
        body { 
            font-family: Arial, sans-serif; 
            text-align: center; 
            padding: 50px; 
            background: #0f1419; 
            color: #e2e8f0; 
        }
        .error { color: #f56565; margin-bottom: 20px; }
    </style>
</head>
<body>
    <h1 class="error">Template Rendering Error</h1>
    <p>Unable to load dashboard template. Please check the console for details.</p>
</body>
</html>`;
        }
    }

    }

    // Enhanced token validation with timing-safe comparison and expiration
    isValidToken(providedToken) {
        if (!providedToken || typeof providedToken !== 'string') {
            return false;
        }
        
        // Check token expiration
        if (Date.now() > this.tokenExpiry) {
            logger.info(chalk.yellow('🔐 Token expired, generating new token'));
            this.regenerateToken();
            return false;
        }
        
        // Timing-safe comparison to prevent timing attacks
        const expectedBuffer = Buffer.from(this.sessionToken, 'hex');
        const providedBuffer = Buffer.from(providedToken, 'hex');
        
        // Ensure same length to prevent timing leaks
        if (expectedBuffer.length !== providedBuffer.length) {
            return false;
        }
        
        return crypto.timingSafeEqual(expectedBuffer, providedBuffer);
    }
    
    // Token regeneration method
    regenerateToken() {
        this.sessionToken = crypto.randomBytes(64).toString('hex');
        this.tokenExpiry = Date.now() + (parseInt(process.env.WEBUI_TOKEN_EXPIRY_HOURS) || 24) * 60 * 60 * 1000;
        
        const maskedToken = this.sessionToken.substring(0, 8) + '...';
        logger.info(chalk.cyan(`🔐 New WebUI Access Token: ${maskedToken}`));
        logger.info(chalk.gray(`Token expires: ${new Date(this.tokenExpiry).toLocaleString()}`));
    }
}
module.exports = WebUI;
